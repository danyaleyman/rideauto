# Скопируйте на сервер: /etc/default/rideauto-scrapers (опционально, если юниты ещё с User=www-data).
# На rideauto prod Encar-каталог идёт от rideauto → /etc/default/rideauto (см. rideauto_catalog_install.sh).
#
#   sudo cp deploy/env.rideauto-scrapers.example /etc/default/rideauto-scrapers
#   sudo sed -i 's/CHANGEME/ваш_пароль/' /etc/default/rideauto-scrapers   # если пароль не дефолтный wra
#   sudo chown root:www-data /etc/default/rideauto-scrapers
#   sudo chmod 640 /etc/default/rideauto-scrapers
#
# Один DSN на хост 127.0.0.1 (порт Postgres проброшен из Docker), пользователь как в compose.
DATABASE_URL=postgresql://wra:wra@127.0.0.1:5432/wra

# Encar через HTTP-прокси (запятая = несколько URL для ротации в скрейпере)
# sudo bash /opt/rideauto/deploy/scripts/encar_set_proxy_urls.sh /etc/default/rideauto-scrapers 'http://USER:PASS@geo.floppydata.com:10080' www-data
# ENCAR_PROXY_URLS=http://USER:PASS@geo.floppydata.com:10080
