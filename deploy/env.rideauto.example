# Скопируйте на сервер в /etc/default/rideauto. Токен бота НЕ храните в git.
# Ночной Encar-каталог: только rideauto-auto-update — см. deploy/scripts/rideauto_catalog_install.sh
# Права: иначе юниты с User=rideauto не смогут прочитать файл (no dot-source / EnvironmentFile):
#   sudo chown root:rideauto /etc/default/rideauto && sudo chmod 640 /etc/default/rideauto
TELEGRAM_BOT_TOKEN=
SUBSCRIPTIONS_ADMIN_KEY=
PUBLIC_SITE_URL=https://rideauto.ru

# Скраперы Encar + Dongchedi (www-data): отдельный файл /etc/default/rideauto-scrapers — см. deploy/env.rideauto-scrapers.example
#
# DSN Postgres с хоста VPS (для ночного run_meilisearch_sync_host.sh): порт 5432 на 127.0.0.1, не имя контейнера.
# SYNC_PG_DSN=postgresql://wra:ПАРОЛЬ@127.0.0.1:5432/wra
# Для rideauto-auto-update (если используете): тот же DSN подставьте в DATABASE_URL — подменит db_config в backend/config.json.
# DATABASE_URL=postgresql://wra:ПАРОЛЬ@127.0.0.1:5432/wra
#
# Encar: HTTP-прокси (ротация), несколько URL через запятую — подхватывает encar_scraper / encar_daily_update (load_config).
# На сервере без правки репо: sudo bash /opt/rideauto/deploy/scripts/encar_set_proxy_urls.sh /etc/default/rideauto 'http://LOGIN:PASSWORD@geo.floppydata.com:10080'
# Пример узла FloppyData (логин/пароль только из личного кабинета, не в git):
# ENCAR_PROXY_URLS=http://LOGIN:PASSWORD@geo.floppydata.com:10080
# После скрейпера postgres_catalog_sync → auto_learn_engine_map: только при явном включении (по умолчанию выкл.).
# WRA_LEARN_ENGINE_MAP=1
# Разовый тест Encar на лимите «20 новых INSERT»: только вручную, не для systemd.
#   sudo -u rideauto env WRA_SCRAPER_CONFIG=/opt/rideauto/deploy/scraper_config.probe-20.yaml bash .../run_encar_daily_once_prod.sh
# Meilisearch с хоста (если порт проброшен): WRA_MEILISEARCH_URL=http://127.0.0.1:7700
# MEILI_MASTER_KEY=   # точно то же значение, что MEILI_MASTER_KEY в /opt/rideauto/.env (compose подставляет его в контейнеры meilisearch и api)
# Безопасная публикация индекса (полная перезаливка в staging, затем swap с боевым UID — см. deploy/docs/RUNBOOK_OPERATIONS.md):
# WRA_MEILISEARCH_INDEX=cars_build
# WRA_MEILI_LIVE_INDEX=cars
# WRA_MEILI_SWAP_INTO_LIVE=1
#
# --- Clean read rollout (блок D): см. backend/docs/BLOCK_D_CLEAN_ROLLOUT.md ---
# WRA_CLEAN_READ_MODE=1
# WRA_CLEAN_READ_PERCENT=10
# WRA_LEGACY_FALLBACKS_ENABLED=1
# WRA_API_CONTRACT_VERSION=v1

# Ops-алерты: одно из двух — (A) Slack-приложение в workspace или (B) incoming webhook
# (A) Slack app: Bot User OAuth Token + channel id (C…/G…), бот приглашён в канал, scope chat:write
# PARSER_AUDIT_SLACK_BOT_TOKEN=xoxb-...
# PARSER_AUDIT_SLACK_CHANNEL_ID=C0123…
# (B) Webhook (проще, без OAuth)
# PARSER_AUDIT_SLACK_WEBHOOK=https://hooks.slack.com/services/...

# --- HP catalog auto-fill (LLM) ---
# Filler service: deploy/systemd/rideauto-hp-catalog-fill.service
# At least one key is required when provider=auto.
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=

# --- Каталог (опционально) ---
# Прометеус: scrape https://rideauto.ru/api/metrics при WRA_PROMETHEUS_METRICS=1
# WRA_PROMETHEUS_METRICS=1
# Глубокая нумерация page без cursor: лимит для анонимов (по умолчанию 80). -1 = отключить проверку.
# WRA_CATALOG_MAX_PAGE_OFFSET_ANON=80
# Для Bearer-сессии: 0 = без лимита; иначе макс. номер страницы без cursor.
# WRA_CATALOG_MAX_PAGE_OFFSET_AUTH=0
# TTL кэша фасетов в воркере (сек), по умолчанию в коде 300.
# WRA_FACETS_CACHE_TTL=300
#
# --- Форма заявки /buy → POST /api/lead (без SMTP заявки не отправляются, API вернёт 503) ---
# WRA_LEAD_EMAIL_TO=danyaleyman@yandex.ru
# WRA_LEAD_SMTP_HOST=smtp.yandex.ru
# WRA_LEAD_SMTP_PORT=465
# WRA_LEAD_SMTP_USER=ваш_ящик@yandex.ru
# WRA_LEAD_SMTP_PASSWORD=пароль_приложения
# Для порта 587: WRA_LEAD_SMTP_PORT=587 и WRA_LEAD_SMTP_USE_TLS=1

# --- Auth (magic link по email) ---
# WRA_AUTH_ENABLED=true
# WRA_AUTH_SECRET=длинный_случайный_секрет_минимум_32_символа
# WRA_AUTH_COOKIE_NAME=wra_session
# WRA_AUTH_COOKIE_SECURE=true
# WRA_AUTH_MAGIC_TTL_MIN=20
# WRA_AUTH_SESSION_TTL_HOURS=720
# WRA_AUTH_MAGIC_LINK_BASE_URL=https://rideauto.ru
# WRA_AUTH_RATE_LIMIT_PER_IP_HOUR=40
# WRA_AUTH_RATE_LIMIT_PER_EMAIL_HOUR=10
# WRA_AUTH_SMTP_HOST=smtp.yandex.ru
# WRA_AUTH_SMTP_PORT=465
# WRA_AUTH_SMTP_USER=ваш_ящик@yandex.ru
# WRA_AUTH_SMTP_PASSWORD=пароль_приложения
# WRA_AUTH_SMTP_USE_TLS=0
# WRA_AUTH_EMAIL_FROM=World Ride Auto <no-reply@rideauto.ru>
