# Скопируйте на сервер: /etc/default/prod-encar-scrapers
# Читает User=www-data из encar-update / dongchedi-update (группа www-data должна иметь доступ).
#
#   sudo cp deploy/env.prod-encar-scrapers.example /etc/default/prod-encar-scrapers
#   sudo sed -i 's/CHANGEME/ваш_пароль/' /etc/default/prod-encar-scrapers   # если пароль не дефолтный wra
#   sudo chown root:www-data /etc/default/prod-encar-scrapers
#   sudo chmod 640 /etc/default/prod-encar-scrapers
#
# Один DSN на хост 127.0.0.1 (порт Postgres проброшен из Docker), пользователь как в compose.
DATABASE_URL=postgresql://wra:wra@127.0.0.1:5432/wra

# Encar через HTTP-прокси (запятая = несколько URL для ротации в скрейпере)
# sudo bash /opt/prod-encar/deploy/scripts/encar_set_proxy_urls.sh /etc/default/prod-encar-scrapers 'http://USER:PASS@geo.floppydata.com:10080' www-data
# ENCAR_PROXY_URLS=http://USER:PASS@geo.floppydata.com:10080
