[Unit]
Description=Prod Encar daily update job
After=network.target
# Права: User=www-data должен писать encar_cars.db, encar_china.db (Dongchedi), scraper_checkpoint.db, logs/
# sudo bash /opt/prod-encar/deploy/scripts/ensure_scraper_runtime_permissions.sh

[Service]
Type=oneshot
User=www-data
Group=www-data
WorkingDirectory=/opt/prod-encar
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/prod-encar/.venv/bin/python /opt/prod-encar/backend/auto_update.py --config /opt/prod-encar/backend/config.json --type daily --workers 8
TimeoutStartSec=24h
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/opt/prod-encar
