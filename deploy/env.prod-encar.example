# Скопируйте на сервер в /etc/default/prod-encar. Токен бота НЕ храните в git.
# Ночной Encar-каталог: только prod-encar-auto-update — см. deploy/scripts/prod_encar_catalog_install.sh
# Права: иначе юниты с User=prod-encar не смогут прочитать файл (no dot-source / EnvironmentFile):
#   sudo chown root:prod-encar /etc/default/prod-encar && sudo chmod 640 /etc/default/prod-encar
TELEGRAM_BOT_TOKEN=
SUBSCRIPTIONS_ADMIN_KEY=
PUBLIC_SITE_URL=https://rideauto.ru

# Скраперы Encar + Dongchedi (www-data): отдельный файл /etc/default/prod-encar-scrapers — см. deploy/env.prod-encar-scrapers.example
#
# DSN Postgres с хоста VPS (для ночного run_meilisearch_sync_host.sh): порт 5432 на 127.0.0.1, не имя контейнера.
# SYNC_PG_DSN=postgresql://wra:ПАРОЛЬ@127.0.0.1:5432/wra
# Для prod-encar-auto-update (если используете): тот же DSN подставьте в DATABASE_URL — подменит db_config в backend/config.json.
# DATABASE_URL=postgresql://wra:ПАРОЛЬ@127.0.0.1:5432/wra
#
# Encar: HTTP-прокси (ротация), несколько URL через запятую — подхватывает encar_scraper / encar_daily_update (load_config).
# На сервере без правки репо: sudo bash /opt/prod-encar/deploy/scripts/encar_set_proxy_urls.sh /etc/default/prod-encar 'http://LOGIN:PASSWORD@geo.floppydata.com:10080'
# Пример узла FloppyData (логин/пароль только из личного кабинета, не в git):
# ENCAR_PROXY_URLS=http://LOGIN:PASSWORD@geo.floppydata.com:10080
# После скрейпера postgres_catalog_sync → auto_learn_engine_map: только при явном включении (по умолчанию выкл.).
# WRA_LEARN_ENGINE_MAP=1
# Meilisearch с хоста (если порт проброшен): WRA_MEILISEARCH_URL=http://127.0.0.1:7700
# MEILI_MASTER_KEY=

# --- Каталог (опционально) ---
# Прометеус: scrape https://rideauto.ru/api/metrics при WRA_PROMETHEUS_METRICS=1
# WRA_PROMETHEUS_METRICS=1
# Глубокая нумерация page без cursor: лимит для анонимов (по умолчанию 80). -1 = отключить проверку.
# WRA_CATALOG_MAX_PAGE_OFFSET_ANON=80
# Для Bearer-сессии: 0 = без лимита; иначе макс. номер страницы без cursor.
# WRA_CATALOG_MAX_PAGE_OFFSET_AUTH=0
# TTL кэша фасетов в воркере (сек), по умолчанию в коде 300.
# WRA_FACETS_CACHE_TTL=300
