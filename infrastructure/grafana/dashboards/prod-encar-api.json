      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(rate(wra_http_requests_total[5m]))",
          "legendFormat": "rps",
          "refId": "A"
        }
      ],
      "title": "HTTP request rate",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"max": 1, "min": 0, "unit": "percentunit"},
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(rate(wra_http_requests_total{status_class=\"5xx\"}[5m])) / sum(rate(wra_http_requests_total[5m]))",
          "legendFormat": "5xx / all",
          "refId": "A"
        }
      ],
      "title": "HTTP error rate (5xx / all)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"max": 1, "min": 0, "unit": "percentunit"},
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(rate(wra_cache_lookups_total{result=\"hit\"}[5m])) / sum(rate(wra_cache_lookups_total[5m]))",
          "legendFormat": "hit ratio",
          "refId": "A"
        }
      ],
      "title": "Redis JSON cache hit rate",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "id": 4,
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "showLegend": true}},
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.50, sum(rate(wra_http_request_duration_seconds_bucket[5m])) by (le, path_group))",
          "legendFormat": "p50 {{path_group}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.95, sum(rate(wra_http_request_duration_seconds_bucket[5m])) by (le, path_group))",
          "legendFormat": "p95 {{path_group}}",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.99, sum(rate(wra_http_request_duration_seconds_bucket[5m])) by (le, path_group))",
          "legendFormat": "p99 {{path_group}}",
          "refId": "C"
        }
      ],
      "title": "Request latency (by path_group)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "id": 5,
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "showLegend": true}},
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (status_class) (rate(wra_http_requests_total[5m]))",
          "legendFormat": "{{status_class}}",
          "refId": "A"
        }
      ],
      "title": "Request rate by status class",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "id": 6,
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "showLegend": true}},
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (segment, result) (rate(wra_cache_lookups_total[5m]))",
          "legendFormat": "{{segment}} {{result}}",
          "refId": "A"
        }
      ],
      "title": "Cache lookups (hit/miss by segment)",
      "type": "timeseries"
    }
  ],
