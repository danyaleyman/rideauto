# Скопируйте в ``.env`` в корне репозитория: cp .env.example .env
# Docker Compose подставляет переменные из ``.env`` при ``docker compose up``.

# -----------------------------------------------------------------------------
# PostgreSQL (сервис ``postgres``)
# -----------------------------------------------------------------------------
POSTGRES_USER=wra
POSTGRES_PASSWORD=wra
POSTGRES_DB=wra
# Порт на хосте (контейнер слушает 5432)
POSTGRES_PORT=5432

# asyncpg DSN: хост ``postgres`` — имя сервиса в сети compose.
# Если меняете пароль/пользователя/БД — обновите и эту строку (спецсимволы в пароле URL-кодируйте).
WRA_PG_DSN=postgresql://wra:wra@postgres:5432/wra
#
# ВАЖНО: не подставляйте сюда 127.0.0.1 «как на хосте». Сервис ``api`` в Docker подключается к БД
# по внутренней сети; 127.0.0.1 внутри контейнера — не Postgres → asyncpg: Connection refused.
# Для скриптов на хосте (postgres_catalog_sync, repair) используйте отдельно DATABASE_URL с 127.0.0.1
# в scraper_config / /etc/default/rideauto, не перезаписывая WRA_PG_DSN для compose.

# -----------------------------------------------------------------------------
# Redis (сервис ``redis``)
# -----------------------------------------------------------------------------
REDIS_PORT=6379
WRA_REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Meilisearch (сервис ``meilisearch``)
# -----------------------------------------------------------------------------
MEILI_PORT=7700
# Пусто = без ключа (только для dev). В проде задайте длинный секрет.
MEILI_MASTER_KEY=
MEILI_ENV=development
WRA_MEILISEARCH_URL=http://meilisearch:7700
# Не используйте http://127.0.0.1:7700 для сервиса ``api`` в Docker — внутри контейнера это не Meilisearch.
WRA_MEILISEARCH_INDEX=cars

# -----------------------------------------------------------------------------
# API (сервис ``api``, FastAPI + uvicorn)
# -----------------------------------------------------------------------------
API_PORT=8080
WRA_IMAGE_CACHE_DIR=/app/var/image_cache
WRA_CACHE_INVALIDATE_SECRET=
WRA_METRICS_ENABLED=true
WRA_AUTH_ENABLED=true
# Обязательно смените в проде:
WRA_AUTH_SECRET=change_me_long_random_secret
WRA_AUTH_COOKIE_NAME=wra_session
WRA_AUTH_COOKIE_SECURE=true
WRA_AUTH_MAGIC_TTL_MIN=20
WRA_AUTH_SESSION_TTL_HOURS=720
WRA_AUTH_MAGIC_LINK_BASE_URL=https://rideauto.ru
WRA_AUTH_RATE_LIMIT_PER_IP_HOUR=40
WRA_AUTH_RATE_LIMIT_PER_EMAIL_HOUR=10
WRA_AUTH_SMTP_HOST=smtp.yandex.ru
WRA_AUTH_SMTP_PORT=465
WRA_AUTH_SMTP_USER=
WRA_AUTH_SMTP_PASSWORD=
WRA_AUTH_SMTP_USE_TLS=false
WRA_AUTH_EMAIL_FROM=

# Дополнительно (см. fastapi_app.config.Settings, префикс WRA_):
# WRA_CACHE_TTL_SEARCH_SEC=10
# WRA_CACHE_TTL_FACETS_SEC=30
# WRA_CACHE_TTL_CAR_SEC=60

# -----------------------------------------------------------------------------
# Скрапер Encar (вне compose): по умолчанию storage.backend=postgres в scraper_config.yaml
# -----------------------------------------------------------------------------
# Один из вариантов обязателен для записи в БД:
# DATABASE_URL=postgresql://wra:wra@127.0.0.1:5432/wra
#
# Локальные переопределения без правок общего YAML: scraper_config.local.yaml в корне репо
# (см. scraper_config.local.example.yaml). Скрипт: backend/scripts/run_encar_local_daily.ps1 или .sh
#
# Encar HTTP-прокси (не коммитить в git): несколько URL через запятую
# ENCAR_PROXY_URLS=http://user:pass@proxy1:10080,http://user:pass@proxy2:10080

# -----------------------------------------------------------------------------
# Next.js (сервис ``web`` в compose)
# -----------------------------------------------------------------------------
WEB_PORT=3000
# Внутри compose SSR и rewrites ходят на сервис ``api`` (не меняйте без причины).
WRA_API_INTERNAL=http://api:8080

# Публичный базовый URL API для браузера. Оставьте пустым: запросы идут на /api на том же origin,
# Next (rewrites) проксирует на WRA_API_INTERNAL — так корректно и в Docker по IP, и за nginx.
# Укажите полный URL только если API на другом домене, например: https://rideauto.ru
NEXT_PUBLIC_API_BASE=

# Канонический origin сайта (Open Graph, metadataBase). Без слэша на конце.
NEXT_PUBLIC_SITE_URL=https://rideauto.ru

